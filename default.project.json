{
  "name": "Cultivation",
  "emitLegacyScripts": false,
  "serveAddress": "0.0.0.0",
  "servePort": 34872,
  "tree": {
    "$className": "DataModel",
    "ReplicatedFirst": {
      "$path": "src/ReplicatedFirst"
    },
    "ReplicatedStorage": {
      "$path": "src/ReplicatedStorage"
    },
    "ServerStorage": {
      "$path": "src/ServerStorage",
      "Scripts": {
        "$path": "scripts"
      }
    },
    "ServerScriptService": {
      "$path": "src/ServerScriptService"
    },
    "StarterPlayer": {
      "StarterCharacterScripts": {
        "$path": "src/StarterCharacterScripts"
      },
      "StarterPlayerScripts": {
        "$path": "src/StarterPlayerScripts"
      }
    },
    "Workspace": {
      "$path": "src/Workspace",
      "Terrain": {
        "$className": "Terrain"
      }
    },
    "Lighting": {
      "$path": "src/Lighting"
    }
  }
}
